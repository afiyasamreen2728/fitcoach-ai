# Copy this file to backend/.env for local development and fill in a real key.
# NEVER commit the real .env file to version control.

ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: override the default model
# ANTHROPIC_MODEL=claude-sonnet-4-5

# Optional: force mock mode (simulated streaming responses, no real API calls
# or API key needed). Useful for building/demoing the UI before your
# Anthropic account is funded. Mock mode also turns on automatically if
# ANTHROPIC_API_KEY is left empty above, so this line is only needed if you
# want to force mock mode even when a real key IS set.
# MOCK_MODE=true
